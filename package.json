{
  "name": "nardo",
  "version": "0.1.0",
  "description": "Local-first memory system for AI agents",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/lesliesrussell/nardo.git"
  },
  "keywords": ["memory", "ai", "mcp", "local-first", "rag", "embeddings"],
  "license": "MIT",
